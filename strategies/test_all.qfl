@using ema:5
@using bb:20:2.0

@persist call_count : i64 = 0

on trade(t) {
    call_count = call_count + 1
    feature price = t.price
    feature ema = quince.get("ema")

    feature px = quince.price()
    feature pos = quince.position()

    if ema > 0 and call_count > 5 {
        quince.order(0, 0.5, 0)
        quince.log("test_all: buy signal")
    }
}

on depth() {
    quince.log("test_all: depth update")
}

on fill(f) {
    feature fill_price = f.price
    feature fill_qty = f.qty
    quince.log("test_all: fill received")
}

on eval() {
    feature bal = quince.balance("USDT")
    feature pos = quince.position()
    feature cnt = call_count
    feature price = quince.price()
    quince.log("test_all: eval")
}
